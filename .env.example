# ── Required ──────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHANNEL_ID=-100xxxxxxxxxx

# ── Liquidation filter ────────────────────────────────────
# Minimum USD value to trigger an alert (default: 50000)
# MIN_LIQUIDATION_USD=50000

# ── WebSocket ─────────────────────────────────────────────
# ASTER_WS_URL=wss://fstream.asterdex.com/ws/!forceOrder@arr
# WEBSOCKET_PING_INTERVAL=20
# WEBSOCKET_PING_TIMEOUT=15
# MAX_CONNECTION_LIFETIME=3600

# ── Reconnection ─────────────────────────────────────────
# RECONNECT_DELAY=5
# MAX_RECONNECT_ATTEMPTS=10

# ── Logging ──────────────────────────────────────────────
# LOG_LEVEL=INFO
# STATUS_UPDATE_INTERVAL=300
